model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

/// dimension tables from the sales_pipeline database
queryGroup 'sales_pipeline dimensions'

	annotation PBI_QueryGroupOrder = 0

/// fact tables from the sales_pipeline database
queryGroup 'sales_pipeline fact'

	annotation PBI_QueryGroupOrder = 1

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["dim_accounts","dim_date","dim_sales_reps","bridge_opportunity_date","fact_opportunities"]

annotation PBI_ProTooling = ["DevMode","MCP-PBIModeling"]

ref table dim_accounts
ref table bridge_opportunity_date
ref table dim_date
ref table dim_sales_reps
ref table fact_opportunities

ref cultureInfo en-US

