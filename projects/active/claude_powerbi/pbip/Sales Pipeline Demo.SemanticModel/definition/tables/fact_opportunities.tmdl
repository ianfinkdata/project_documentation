		dataType: int64
		formatString: 0
		lineageTag: ae8b7563-c16a-4bde-a399-4d12b6ee609b
		summarizeBy: none
		sourceColumn: sales_rep_id

		annotation SummarizationSetBy = Automatic

	/// Identifier for the product associated with this opportunity.
	column product_id
		dataType: int64
		formatString: 0
		lineageTag: c64ddb11-7e9d-4478-ab63-269092eac6de
		summarizeBy: none
		sourceColumn: product_id

		annotation SummarizationSetBy = Automatic

	/// Date the opportunity was created in the CRM system.
	column created_date
		dataType: dateTime
		formatString: Short Date
		lineageTag: ed1aadf3-f0bc-4fb6-832d-7199d116e5bb
		summarizeBy: none
		sourceColumn: created_date

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	/// Projected date by which the opportunity is expected to close.
	column expected_close_date
		dataType: dateTime
		formatString: Short Date
		lineageTag: 20ea19fe-59be-4509-aa38-adb6d7734041
		summarizeBy: none
		sourceColumn: expected_close_date

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

