		formatString: 0
		lineageTag: a1ceb38c-8e6e-4bba-ba0c-8c2595016589
		summarizeBy: sum
		sourceColumn: is_open

		annotation SummarizationSetBy = Automatic

	/// Flag indicating the opportunity was closed as lost (1=Lost, 0=Otherwise).
	column is_lost
		dataType: int64
		formatString: 0
		lineageTag: 89537c25-89cd-47b3-9cc1-efb8a34974aa
		summarizeBy: sum
		sourceColumn: is_lost

		annotation SummarizationSetBy = Automatic

