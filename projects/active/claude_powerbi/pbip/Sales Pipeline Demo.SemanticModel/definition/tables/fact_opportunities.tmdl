	column actual_close_date
		dataType: dateTime
		formatString: Short Date
		lineageTag: 7a04bdae-a842-41bd-a09f-e77a632284cf
		summarizeBy: none
		sourceColumn: actual_close_date

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	/// Current sales pipeline stage of the opportunity (e.g., Prospecting, Proposal, Negotiation, Closed Won).
	column stage
		dataType: string
		lineageTag: f911b72f-a4c8-4b16-9635-d566e4cff926
		summarizeBy: none
		sourceColumn: stage

		annotation SummarizationSetBy = Automatic

	/// Channel or source through which the lead was generated (e.g., Inbound, Referral, Outbound).
	column lead_source
		dataType: string
		lineageTag: 3185b0f1-aed6-4d79-a848-0c577c763c8a
		summarizeBy: none
		sourceColumn: lead_source

		annotation SummarizationSetBy = Automatic

	/// Total deal value of the opportunity in US dollars.
	column amount
		dataType: double
		lineageTag: c2fe0ddd-b435-48a5-b274-745c46a7e237
		summarizeBy: sum
		sourceColumn: amount

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Number of units or licenses associated with the opportunity.
	column quantity
		dataType: int64
		formatString: 0
		lineageTag: df4e4855-53f2-49b2-9754-4fc04728fa8e
		summarizeBy: sum
		sourceColumn: quantity

		annotation SummarizationSetBy = Automatic

	/// Estimated likelihood of winning the opportunity expressed as a decimal (0.0 to 1.0).
	column probability
		dataType: double
		lineageTag: 7fdb0aeb-ceef-4bcf-82c7-0c4dbd86c9bd
		summarizeBy: sum
		sourceColumn: probability

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Indicates whether the opportunity has been closed, either won or lost (true/false).
	column is_closed
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: c0bc6e8d-f9b9-4a64-a99c-bb6b97ded626
		summarizeBy: none
		sourceColumn: is_closed

		annotation SummarizationSetBy = Automatic

