		summarizeBy: sum
		sourceColumn: weighted_amount

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Flag indicating the opportunity is still active and in progress (1=Open, 0=Closed).
	column is_open
