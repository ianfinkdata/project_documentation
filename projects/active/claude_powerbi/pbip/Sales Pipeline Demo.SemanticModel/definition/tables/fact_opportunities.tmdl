	column opportunity_name
		dataType: string
		lineageTag: 29b1cef1-f3da-4b27-a4ce-1c157cc367c0
		summarizeBy: none
		sourceColumn: opportunity_name

		annotation SummarizationSetBy = Automatic

	/// Foreign key linking to the dim_accounts table.
	column account_id
		dataType: int64
		formatString: 0
		lineageTag: fd147b7b-c618-4b34-81bd-d72bade2e1c1
		summarizeBy: none
		sourceColumn: account_id

		annotation SummarizationSetBy = Automatic

	/// Foreign key linking to the dim_sales_reps table.
